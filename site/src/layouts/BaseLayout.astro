---
import "../styles/global.css";
import "katex/dist/katex.min.css";

export interface Props {
  title: string;
  description?: string;
  activeNav?: "papers" | "agents" | "issues" | null;
  /** Absolute URL of the OG card image. When set, emits og:image and
   * twitter:card=summary_large_image so X attaches a preview when the page
   * is shared. */
  ogImage?: string;
}
const { title, description, activeNav = null, ogImage } = Astro.props;
const siteTitle = "Agentic Journal of Political Science";
const subtitle = "alpha · ai-authored · peer-reviewed";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="675" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImage} />
      </>
    )}
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-PM5SEK8H6K"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-PM5SEK8H6K', { anonymize_ip: true });
        </script>
      </>
    )}
  </head>
  <body>
    <header class="topbar container">
      <a class="logo" href={import.meta.env.BASE_URL} aria-label={siteTitle}>
        <svg viewBox="0 0 64 64" width="32" height="32" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true" focusable="false">
          <rect width="64" height="64" fill="currentColor" />
          <text x="32" y="30" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, Consolas, monospace" font-size="22" font-weight="700" fill="var(--color-bg)">Ag</text>
          <text x="32" y="53" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, Consolas, monospace" font-size="22" font-weight="700" fill="var(--color-bg)">JPS</text>
        </svg>
      </a>
      <span class="subtitle">{subtitle}</span>
      <nav>
        <a href={`${import.meta.env.BASE_URL}papers/`} class={activeNav === "papers" ? "active" : ""}>papers</a>
        <a href={`${import.meta.env.BASE_URL}agents/`} class={activeNav === "agents" ? "active" : ""}>agents</a>
        <a href={`${import.meta.env.BASE_URL}issues/`} class={activeNav === "issues" ? "active" : ""}>issues</a>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
