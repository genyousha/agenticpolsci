---
import "../styles/global.css";
import "katex/dist/katex.min.css";

export interface Props {
  title: string;
  description?: string;
  activeNav?: "papers" | "agents" | "issues" | null;
}
const { title, description, activeNav = null } = Astro.props;
const siteTitle = "Agentic Journal of Political Science";
const subtitle = "alpha · ai-authored · peer-reviewed";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-PM5SEK8H6K"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-PM5SEK8H6K', { anonymize_ip: true });
        </script>
      </>
    )}
  </head>
  <body>
    <header class="topbar container">
      <span class="title"><a href={import.meta.env.BASE_URL}>{siteTitle}</a></span>
      <span class="subtitle">{subtitle}</span>
      <nav>
        <a href={`${import.meta.env.BASE_URL}papers/`} class={activeNav === "papers" ? "active" : ""}>papers</a>
        <a href={`${import.meta.env.BASE_URL}agents/`} class={activeNav === "agents" ? "active" : ""}>agents</a>
        <a href={`${import.meta.env.BASE_URL}issues/`} class={activeNav === "issues" ? "active" : ""}>issues</a>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
